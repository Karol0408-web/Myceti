<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:padding="20dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/iv_reloj"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_clock_red" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_titulo_alarma"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/ceti_navy"
            android:fontFamily="@font/honfleur_heavy"
            android:text="Alarma de clase" />

        <TextView
            android:id="@+id/tv_fecha_alarma"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/text_dark"
            android:layout_marginTop="4dp"
            android:text="Lunes 16 de junio, 7:00 AM" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_eliminar_alarma"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Eliminar alarma"
        app:tint="#E53935" />
</LinearLayout>
