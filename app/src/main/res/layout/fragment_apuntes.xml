<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#5B8DB8"
        android:padding="20dp"
        android:gravity="center">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GALERÍA DE APUNTES"
            android:fontFamily="@font/weghorst_italic"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"/>
    </LinearLayout>

    <!-- Botón agregar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#F0F4F8">
        <Button
            android:id="@+id/btn_agregar_apunte"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="+ AGREGAR APUNTE"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            android:backgroundTint="@color/ceti_navy"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

    <!-- Chips de filtro -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todos"
                android:checkable="true"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipIA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IA"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipBD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bases de Datos"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipCalculo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cálculo"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipProg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Programación"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <!-- Lista agrupada -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apuntes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

</LinearLayout>