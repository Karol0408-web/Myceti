<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header con botones - AHORA CON ALTURA FIJA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ceti_blue"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HORARIO"
            android:fontFamily="@font/weghorst_italic"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"/>

        <!-- Botones de días - Con altura fija y sin expandirse -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btn_lun"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Lun"
                android:textSize="11sp"
                android:layout_margin="3dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/white"
                app:strokeColor="@color/white"/>

            <Button
                android:id="@+id/btn_mar"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Mar"
                android:textSize="11sp"
                android:layout_margin="3dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/white"
                app:strokeColor="@color/white"/>

            <Button
                android:id="@+id/btn_mie"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Mié"
                android:textSize="11sp"
                android:layout_margin="3dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/white"
                app:strokeColor="@color/white"/>

            <Button
                android:id="@+id/btn_jue"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Jue"
                android:textSize="11sp"
                android:layout_margin="3dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/white"
                app:strokeColor="@color/white"/>

            <Button
                android:id="@+id/btn_vie"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Vie"
                android:textSize="11sp"
                android:layout_margin="3dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/white"
                app:strokeColor="@color/white"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_dia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:text="Hoy"/>
    </LinearLayout>

    <!-- ProgressBar y RecyclerView - AHORA OCUPAN TODO EL ESPACIO RESTANTE -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ceti_red"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone"
            android:text="Error al cargar horario"/>

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No hay clases para este día"
            android:textColor="@color/text_gray"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_clases"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:clipToPadding="false"
            android:background="@color/background_gray"/>

    </FrameLayout>
</LinearLayout>