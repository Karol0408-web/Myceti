<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:padding="20dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/iv_reloj"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_clock_red" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_hora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/ceti_navy"
            android:fontFamily="@font/honfleur_heavy"
            android:text="7:00 AM" />

        <TextView
            android:id="@+id/tv_materia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/text_dark"
            android:layout_marginTop="2dp"
            android:text="Programación estructurada" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tv_turno"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mañana"
                android:textColor="@color/ceti_orange"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_salon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salón L-209"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>