<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fondo">

    <!-- Parte superior con el texto CETI -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CETI"
            android:textSize="45sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="2dp"/>
    </FrameLayout>

    <!-- Tarjeta blanca inferior con bordes redondeados -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_rounded_top"
        android:orientation="vertical"
        android:padding="30dp">

        <!-- Campo No. Registro -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_person"
                app:tint="@color/text_gray"/>

            <EditText
                android:id="@+id/et_registro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="No. Registro"
                android:background="@null"
                android:paddingStart="12dp"
                android:inputType="text"
                android:imeOptions="actionNext"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"/>

        <!-- Campo Contraseña -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/text_gray"/>

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contraseña"
                android:background="@null"
                android:paddingStart="12dp"
                android:inputType="textPassword"
                android:imeOptions="actionDone"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"/>

        <!-- ✅ Opción Recordar datos (nuevo) -->
        <CheckBox
            android:id="@+id/chk_recordar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recordar datos"
            android:textColor="@color/text_gray"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"/>

        <!-- ProgressBar (oculto por defecto) -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <!-- Botón Iniciar Sesión -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:text="INICIAR SESIÓN"
            android:backgroundTint="@color/ceti_navy"
            android:textColor="@color/white"
            style="@style/Widget.MaterialComponents.Button"/>

        <!-- Link Crear una cuenta -->
        <TextView
            android:id="@+id/tv_crear_cuenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crear una cuenta"
            android:textColor="@color/ceti_red"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:padding="8dp"/>
    </LinearLayout>
</LinearLayout>