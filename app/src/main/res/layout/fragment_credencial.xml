<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_gray">

    <!-- Header con título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ceti_blue"
        android:padding="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MI CREDENCIAL"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />


    </LinearLayout>

    <!-- ScrollView centrado -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="16dp">

            <!-- Credencial - Ancho fijo de 300dp (más grande pero no ancha) -->
            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_credencial"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center"
                android:elevation="8dp"
                android:layout_marginVertical="16dp">

                <!-- Logo CETI -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CETI"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:letterSpacing="0.1"
                    android:gravity="center" />

                <View
                    android:layout_width="50dp"
                    android:layout_height="2dp"
                    android:background="@color/white"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <!-- Foto de perfil más grande -->
                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_foto_credencial"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:id="@+id/iv_foto"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/ic_person"
                        android:scaleType="centerCrop"
                        android:padding="3dp" />
                </LinearLayout>

                <!-- Nombre del estudiante -->
                <TextView
                    android:id="@+id/tv_nombre_credencial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:text="Karol Benítez" />

                <!-- Número de control -->
                <TextView
                    android:id="@+id/tv_no_registro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:text="C21345" />

                <!-- Plantel -->
                <TextView
                    android:id="@+id/tv_plantel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:text="Plantel Colomos" />

                <!-- Separador -->
                <View
                    android:layout_width="60dp"
                    android:layout_height="1dp"
                    android:background="#66FFFFFF"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp" />

                <!-- Número de seguro social -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NÚMERO DE SEGURO"
                    android:textColor="#99FFFFFF"
                    android:textSize="9sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tv_seguro_social"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:text="*****" />

                <!-- Código de barras (opcional) -->
                <ImageView
                    android:id="@+id/iv_codigo_barras_visual"
                    android:layout_width="180dp"
                    android:layout_height="45dp"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    android:background="@color/white"
                    android:padding="4dp"
                    android:contentDescription="Código de barras" />

                <TextView
                    android:id="@+id/tv_codigo_barras"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    android:text="" />

            </LinearLayout>

            <!-- Botones -->
            <Button
                android:id="@+id/btn_escanear"
                android:layout_width="280dp"
                android:layout_height="48dp"
                android:text="Escanear tarjeta física"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="@color/ceti_blue"
                android:layout_marginTop="8dp"
                style="@style/Widget.MaterialComponents.Button" />


        </LinearLayout>
    </ScrollView>

</LinearLayout>